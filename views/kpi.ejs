<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>KPI数据看板 - 企业内部培训管理系统</title>
    <link rel="stylesheet" href="/style.css">
    <style>
        body {
            background-image: url('/images/main/bg.jpg');
            background-size: cover;
            background-position: center;
            background-repeat: no-repeat;
            background-attachment: fixed;
            background-color: #667eea;
            min-height: 100vh;
            padding: 20px;
        }

        .header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            flex-wrap: wrap;
            gap: 15px;
            background: rgba(255, 255, 255, 0.92);
            backdrop-filter: blur(2px);
            border-radius: 20px;
            padding: 20px 30px;
            margin-bottom: 30px;
            box-shadow: 0 10px 40px rgba(0, 0, 0, 0.1);
        }

        .back-btn {
            background: linear-gradient(135deg, #667eea, #764ba2);
            color: white;
            border: none;
            padding: 10px 20px;
            border-radius: 10px;
            font-size: 14px;
            cursor: pointer;
            transition: all 0.3s ease;
        }

        .back-btn:hover {
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(102, 126, 234, 0.4);
        }

        .user-info {
            display: flex;
            align-items: center;
            gap: 12px;
            background: rgba(240, 240, 240, 0.9);
            padding: 8px 16px;
            border-radius: 40px;
        }

        .user-avatar {
            width: 36px;
            height: 36px;
            background: linear-gradient(135deg, #667eea, #764ba2);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
            font-size: 18px;
        }

        .user-details {
            display: flex;
            flex-direction: column;
        }

        .user-name {
            font-weight: 600;
            color: #333;
            font-size: 14px;
        }

        .user-dept {
            font-size: 11px;
            color: #888;
        }

        .logout-btn {
            background: none;
            border: 1px solid #ddd;
            padding: 6px 12px;
            border-radius: 20px;
            cursor: pointer;
            font-size: 12px;
            transition: all 0.3s ease;
        }

        .logout-btn:hover {
            background: #f44336;
            color: white;
            border-color: #f44336;
        }

        /* 概览卡片 */
        .overview-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
            gap: 20px;
            margin-bottom: 30px;
        }

        .overview-card {
            background: rgba(255, 255, 255, 0.92);
            backdrop-filter: blur(2px);
            border-radius: 20px;
            padding: 25px;
            text-align: center;
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.1);
            transition: transform 0.3s ease;
        }

        .overview-card:hover {
            transform: translateY(-5px);
        }

        .overview-icon {
            font-size: 40px;
            margin-bottom: 10px;
        }

        .overview-value {
            font-size: 32px;
            font-weight: bold;
            color: #667eea;
            margin-bottom: 5px;
        }

        .overview-label {
            font-size: 13px;
            color: #888;
        }

        /* 主内容区 */
        .stats-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(450px, 1fr));
            gap: 25px;
            margin-bottom: 30px;
        }

        @media (max-width: 768px) {
            .stats-grid {
                grid-template-columns: 1fr;
            }
        }

        .stat-card {
            background: rgba(255, 255, 255, 0.92);
            backdrop-filter: blur(2px);
            border-radius: 20px;
            padding: 25px;
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.1);
        }

        .stat-card h3 {
            font-size: 20px;
            color: #333;
            margin-bottom: 20px;
            padding-bottom: 10px;
            border-bottom: 3px solid #667eea;
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .stat-card .stat-content {
            min-height: 100px;
        }

        .stat-item {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 12px 0;
            border-bottom: 1px solid #eee;
        }

        .stat-item .label {
            color: #555;
            font-weight: 600;
            font-size: 15px;
        }

        .stat-item .value {
            color: #333;
            font-weight: bold;
            font-size: 15px;
        }

        .stat-item .value.highlight {
            color: #667eea;
            font-size: 18px;
        }

        .kpi-bar {
            margin: 8px 0 16px 0;
            background: #e9ecef;
            border-radius: 10px;
            height: 14px;
            overflow: hidden;
            position: relative;
        }

        .kpi-fill {
            background: linear-gradient(90deg, #667eea, #764ba2);
            height: 100%;
            border-radius: 10px;
            transition: width 0.8s ease;
            position: relative;
        }

        .kpi-fill.high {
            background: linear-gradient(90deg, #4caf50, #66bb6a);
        }

        .kpi-fill.medium {
            background: linear-gradient(90deg, #ff9800, #ffb74d);
        }

        .kpi-fill.low {
            background: linear-gradient(90deg, #f44336, #ef5350);
        }

        .usage-low {
            color: #4caf50;
        }

        .usage-medium {
            color: #ff9800;
        }

        .usage-high {
            color: #f44336;
        }

        .dept-detail {
            display: flex;
            justify-content: space-between;
            font-size: 12px;
            color: #999;
            margin-bottom: 4px;
        }

        .footer {
            text-align: center;
            padding: 20px;
            color: rgba(255, 255, 255, 0.9);
            font-size: 12px;
            text-shadow: 1px 1px 2px rgba(0,0,0,0.3);
        }

        .refresh-bar {
            display: flex;
            justify-content: flex-end;
            margin-bottom: 15px;
            gap: 10px;
        }

        .refresh-btn {
            background: rgba(255, 255, 255, 0.85);
            border: 1px solid #ddd;
            padding: 8px 16px;
            border-radius: 8px;
            cursor: pointer;
            font-size: 13px;
            transition: all 0.3s ease;
        }

        .refresh-btn:hover {
            background: #667eea;
            color: white;
            border-color: #667eea;
        }
    </style>
</head>
<body>
    <div class="container">
        <!-- 头部导航 -->
        <div class="header">
            <div class="logo">
                <h1>📊 KPI数据看板</h1>
                <p>Key Performance Indicators Dashboard</p>
            </div>
            <div class="user-info" style="cursor:pointer;" onclick="window.location.href='/profile'" title="点击进入个人中心">
                <div class="user-avatar">👤</div>
                <div class="user-details">
                    <span class="user-name" id="userName">加载中...</span>
                    <span class="user-dept" id="userDept"></span>
                </div>
                <button class="logout-btn" onclick="event.stopPropagation(); logout();">🚪 退出登录</button>
            </div>
            <button class="back-btn" onclick="window.location.href='/main'">🏠 返回首页</button>
        </div>

        <!-- 概览统计卡片 -->
        <div class="overview-grid">
            <div class="overview-card">
                <div class="overview-icon">📈</div>
                <div class="overview-value" id="avgCompletion">--%</div>
                <div class="overview-label">整体培训完成率</div>
            </div>
            <div class="overview-card">
                <div class="overview-icon">👥</div>
                <div class="overview-value" id="totalEmployees">--</div>
                <div class="overview-label">在职员工总数</div>
            </div>
            <div class="overview-card">
                <div class="overview-icon">💰</div>
                <div class="overview-value" id="totalBudgetUsage">--%</div>
                <div class="overview-label">整体预算使用率</div>
            </div>
            <div class="overview-card">
                <div class="overview-icon">🏢</div>
                <div class="overview-value" id="deptCount">--</div>
                <div class="overview-label">参与部门数</div>
            </div>
        </div>

        <!-- 刷新按钮 -->
        <div class="refresh-bar">
            <button class="refresh-btn" onclick="refreshAll()">🔄 刷新数据</button>
        </div>

        <!-- KPI & 预算详情 -->
        <div class="stats-grid">
            <!-- 部门培训KPI -->
            <div class="stat-card">
                <h3>📊 部门培训完成率</h3>
                <div id="kpiData" class="stat-content">
                    <div style="text-align:center;padding:40px;color:#999;">加载中...</div>
                </div>
            </div>

            <!-- 预算使用情况 -->
            <div class="stat-card">
                <h3>💰 部门预算使用情况</h3>
                <div id="budgetData" class="stat-content">
                    <div style="text-align:center;padding:40px;color:#999;">加载中...</div>
                </div>
            </div>
        </div>

        <div class="footer">
            <p>© 2026 企业内部培训管理系统 | 数据实时同步于Oracle数据库 | 数据更新时间: <span id="updateTime">--</span></p>
        </div>
    </div>

    <script>
        // ============= 用户相关 =============

        function getCurrentUser() {
            const userStr = sessionStorage.getItem('user');
            if (!userStr) {
                window.location.href = '/';
                return null;
            }
            return JSON.parse(userStr);
        }

        function displayUserInfo() {
            const user = getCurrentUser();
            if (user) {
                document.getElementById('userName').textContent = user.empName;
                document.getElementById('userDept').textContent = user.deptName || '员工';
            }
        }

        function logout() {
            sessionStorage.removeItem('user');
            window.location.href = '/';
        }

        // ============= 加载KPI数据 =============

        async function loadKPI() {
            try {
                const response = await fetch('/api/kpi');
                const data = await response.json();
                const container = document.getElementById('kpiData');

                if (data.success && data.data.length > 0) {
                    let totalCompleted = 0;
                    let totalEmp = 0;

                    container.innerHTML = data.data.map(dept => {
                        const rate = dept.COMPLETION_RATE || 0;
                        const completed = dept.COMPLETED_EMP || 0;
                        const total = dept.TOTAL_EMP || 0;
                        totalCompleted += completed;
                        totalEmp += total;

                        let fillClass = 'low';
                        if (rate >= 80) fillClass = 'high';
                        else if (rate >= 50) fillClass = 'medium';

                        return `
                            <div class="stat-item">
                                <span class="label">${dept.DEPT_NAME}</span>
                                <span class="value highlight">${rate}%</span>
                            </div>
                            <div class="dept-detail">
                                <span>已完成: ${completed}人</span>
                                <span>总人数: ${total}人</span>
                            </div>
                            <div class="kpi-bar">
                                <div class="kpi-fill ${fillClass}" style="width: ${rate}%"></div>
                            </div>
                        `;
                    }).join('');

                    document.getElementById('avgCompletion').textContent =
                        totalEmp > 0 ? (totalCompleted / totalEmp * 100).toFixed(1) + '%' : '--%';
                    document.getElementById('totalEmployees').textContent = totalEmp || '--';
                    document.getElementById('deptCount').textContent = data.data.length || '--';
                } else {
                    container.innerHTML = '<div style="text-align:center;padding:40px;color:#999;">暂无KPI数据</div>';
                }
            } catch (error) {
                document.getElementById('kpiData').innerHTML =
                    '<div style="text-align:center;padding:40px;color:#f44336;">加载失败: ' + error.message + '</div>';
            }
        }

        // ============= 加载预算数据 =============

        async function loadBudget() {
            try {
                const response = await fetch('/api/budget');
                const data = await response.json();
                const container = document.getElementById('budgetData');

                if (data.success && data.data.length > 0) {
                    let totalUsed = 0;
                    let totalBudget = 0;

                    container.innerHTML = data.data.map(budget => {
                        const usageRate = budget.USAGE_RATE || 0;
                        const used = budget.USED_BUDGET || 0;
                        const annual = budget.ANNUAL_BUDGET || 0;
                        const remain = budget.REMAIN_BUDGET || 0;
                        totalUsed += used;
                        totalBudget += annual;

                        let usageClass = '';
                        if (usageRate > 80) usageClass = 'usage-high';
                        else if (usageRate > 50) usageClass = 'usage-medium';
                        else usageClass = 'usage-low';

                        let fillClass = 'low';
                        if (usageRate > 80) fillClass = 'high';
                        else if (usageRate > 50) fillClass = 'medium';

                        return `
                            <div class="stat-item">
                                <span class="label">${budget.DEPT_NAME}</span>
                                <span class="value">¥${used.toLocaleString()} / ¥${annual.toLocaleString()}</span>
                            </div>
                            <div class="dept-detail">
                                <span>剩余: <strong class="${usageClass}">¥${remain.toLocaleString()}</strong></span>
                                <span>使用率: <strong class="${usageClass}">${usageRate}%</strong></span>
                            </div>
                            <div class="kpi-bar">
                                <div class="kpi-fill ${fillClass}" style="width: ${usageRate}%"></div>
                            </div>
                        `;
                    }).join('');

                    document.getElementById('totalBudgetUsage').textContent =
                        totalBudget > 0 ? (totalUsed / totalBudget * 100).toFixed(1) + '%' : '--%';
                } else {
                    container.innerHTML = '<div style="text-align:center;padding:40px;color:#999;">暂无预算数据</div>';
                }
            } catch (error) {
                document.getElementById('budgetData').innerHTML =
                    '<div style="text-align:center;padding:40px;color:#f44336;">加载失败: ' + error.message + '</div>';
            }
        }

        // ============= 刷新所有 =============

        function refreshAll() {
            document.getElementById('kpiData').innerHTML =
                '<div style="text-align:center;padding:40px;color:#999;">加载中...</div>';
            document.getElementById('budgetData').innerHTML =
                '<div style="text-align:center;padding:40px;color:#999;">加载中...</div>';
            loadKPI();
            loadBudget();
        }

        // ============= 页面初始化 =============

        window.addEventListener('DOMContentLoaded', () => {
            displayUserInfo();
            loadKPI();
            loadBudget();
            document.getElementById('updateTime').textContent = new Date().toLocaleString();
        });
    </script>
</body>
</html>
