<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>企业内部培训管理系统</title>
    <link rel="stylesheet" href="/style.css">
    <style>
        /* 主界面背景图片 */
        body {
            background-image: url('/images/main/bg.jpg');
            background-size: cover;
            background-position: center;
            background-repeat: no-repeat;
            background-attachment: fixed;
            background-color: #667eea;
            min-height: 100vh;
            padding: 20px;
        }
        
        /* 头部导航 */
        .header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            flex-wrap: wrap;
            gap: 15px;
            background: rgba(255, 255, 255, 0.92);
            backdrop-filter: blur(2px);
            border-radius: 20px;
            padding: 20px 30px;
            margin-bottom: 30px;
            box-shadow: 0 10px 40px rgba(0, 0, 0, 0.1);
        }
        
        /* 用户信息区域 */
        .user-info {
            display: flex;
            align-items: center;
            gap: 12px;
            background: rgba(240, 240, 240, 0.9);
            padding: 8px 16px;
            border-radius: 40px;
        }
        
        .user-avatar {
            width: 36px;
            height: 36px;
            background: linear-gradient(135deg, #667eea, #764ba2);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
            font-size: 18px;
        }
        
        .user-details {
            display: flex;
            flex-direction: column;
        }
        
        .user-name {
            font-weight: 600;
            color: #333;
            font-size: 14px;
        }
        
        .user-dept {
            font-size: 11px;
            color: #888;
        }
        
        .logout-btn {
            background: none;
            border: 1px solid #ddd;
            padding: 6px 12px;
            border-radius: 20px;
            cursor: pointer;
            font-size: 12px;
            transition: all 0.3s ease;
        }
        
        .logout-btn:hover {
            background: #f44336;
            color: white;
            border-color: #f44336;
        }
        
        /* 统计卡片 */
        .stats-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
            gap: 25px;
            margin-bottom: 30px;
        }
        
        .stat-card {
            background: rgba(255, 255, 255, 0.92);
            backdrop-filter: blur(2px);
            border-radius: 20px;
            padding: 20px;
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.1);
            transition: transform 0.3s ease;
        }
        
        .section {
            background: rgba(255, 255, 255, 0.92);
            backdrop-filter: blur(2px);
            border-radius: 20px;
            padding: 25px;
            margin-bottom: 30px;
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.1);
        }
        
        .section-title {
            font-size: 22px;
            color: #333;
            margin-bottom: 20px;
            padding-bottom: 10px;
            border-bottom: 3px solid #667eea;
            display: flex;
            align-items: center;
            gap: 10px;
        }
        
        .form-card {
            background: rgba(248, 249, 250, 0.9);
            border-radius: 15px;
            padding: 20px;
            margin-bottom: 25px;
        }
        
        .form-row {
            display: flex;
            flex-wrap: wrap;
            gap: 15px;
            align-items: flex-end;
        }
        
        .form-group {
            flex: 1;
            min-width: 150px;
        }
        
        .form-group label {
            display: block;
            font-size: 12px;
            color: #666;
            margin-bottom: 5px;
        }
        
        .form-group input,
        .form-group select {
            width: 100%;
            padding: 10px 12px;
            border: 1px solid #ddd;
            border-radius: 8px;
            font-size: 14px;
        }
        
        .btn {
            padding: 10px 24px;
            border: none;
            border-radius: 8px;
            font-size: 14px;
            cursor: pointer;
            transition: all 0.3s ease;
            font-weight: 500;
        }
        
        .btn-primary {
            background: linear-gradient(135deg, #667eea, #764ba2);
            color: white;
        }
        
        .btn-success {
            background: #4caf50;
            color: white;
        }
        
        .btn-warning {
            background: #ff9800;
            color: white;
        }
        
        .btn-sm {
            padding: 5px 12px;
            font-size: 12px;
        }
        
        .data-table {
            width: 100%;
            border-collapse: collapse;
        }
        
        .data-table th {
            background: rgba(102, 126, 234, 0.9);
            color: white;
            padding: 12px 15px;
            text-align: left;
            font-weight: 600;
        }
        
        .data-table td {
            padding: 12px 15px;
            border-bottom: 1px solid #eee;
        }
        
        .data-table tr:hover {
            background: rgba(0, 0, 0, 0.05);
        }
        
        .status-badge {
            display: inline-block;
            padding: 4px 12px;
            border-radius: 20px;
            font-size: 12px;
            font-weight: 500;
        }
        
        .status-booked {
            background: #e3f2fd;
            color: #2196f3;
        }
        
        .status-signed {
            background: #e8f5e9;
            color: #4caf50;
        }
        
        .stars {
            color: #ffc107;
        }
        
        .result-box {
            margin-top: 15px;
            padding: 12px 15px;
            border-radius: 8px;
            font-size: 14px;
        }
        
        .result-box.success {
            background: #e8f5e9;
            color: #4caf50;
            border-left: 4px solid #4caf50;
        }
        
        .result-box.error {
            background: #ffebee;
            color: #f44336;
            border-left: 4px solid #f44336;
        }
        
        .footer {
            text-align: center;
            padding: 20px;
            color: rgba(255, 255, 255, 0.9);
            font-size: 12px;
            text-shadow: 1px 1px 2px rgba(0,0,0,0.3);
        }
        
        .hidden {
            display: none;
        }
        
        .nav-menu {
            display: flex;
            gap: 15px;
            flex-wrap: wrap;
        }
        
        .nav-btn {
            padding: 10px 20px;
            background: rgba(240, 240, 240, 0.9);
            border: none;
            border-radius: 10px;
            font-size: 14px;
            cursor: pointer;
            transition: all 0.3s ease;
        }
        
        .nav-btn.active {
            background: #667eea;
            color: white;
        }
        
        .table-container {
            overflow-x: auto;
        }
    </style>
</head>
<body>
    <div class="container">
        <!-- 头部导航 -->
        <div class="header">
            <div class="logo">
                <h1>🎓 企业内部培训管理系统</h1>
                <p>Enterprise Training Management System</p>
            </div>
            <div class="user-info">
                <div class="user-avatar">👤</div>
                <div class="user-details">
                    <span class="user-name" id="userName">加载中...</span>
                    <span class="user-dept" id="userDept"></span>
                </div>
                <button class="logout-btn" onclick="logout()">🚪 退出登录</button>
            </div>
            <div class="nav-menu">
                <button class="nav-btn active" onclick="showTab('courses')">📚 课程中心</button>
                <button class="nav-btn" onclick="showTab('myTraining')">📋 我的培训</button>
                <button class="nav-btn" onclick="showTab('trainers')">⭐ 讲师风采</button>
                <button class="nav-btn" onclick="showTab('stats')">📊 数据统计</button>
            </div>
        </div>

        <!-- 统计卡片区域 -->
        <div class="stats-grid">
            <div class="stat-card">
                <h3>📊 部门培训KPI</h3>
                <div id="kpiData" class="stat-content">加载中...</div>
            </div>
            <div class="stat-card">
                <h3>💰 预算使用情况</h3>
                <div id="budgetData" class="stat-content">加载中...</div>
            </div>
        </div>

        <!-- 课程中心 Tab -->
        <div id="coursesTab" class="tab-content">
            <div class="section">
                <div class="section-title">
                    <span>📚</span> 可报名课程
                </div>
                <div class="table-container">
                    <table class="data-table" id="coursesTable">
                        <thead>
                            <tr>
                                <th>课程名称</th>
                                <th>类型</th>
                                <th>讲师</th>
                                <th>学时</th>
                                <th>开始时间</th>
                                <th>地点</th>
                                <th>操作</th>
                            </tr>
                        </thead>
                        <tbody></tbody>
                    </table>
                </div>
            </div>

            <!-- 冲突检测（自动使用当前登录用户） -->
            <div class="section">
                <div class="section-title">
                    <span>⚠️</span> 报名冲突检测
                </div>
                <div class="form-card">
                    <div class="form-row">
                        <div class="form-group" style="flex:2">
                            <label>选择课程</label>
                            <select id="checkCourseId" class="form-control"></select>
                        </div>
                        <button class="btn btn-primary" onclick="checkConflict()">🔍 检测冲突</button>
                    </div>
                    <div id="conflictResult" class="result-box" style="display: none;"></div>
                </div>
            </div>

            <!-- 培训签到 -->
            <div class="section">
                <div class="section-title">
                    <span>✅</span> 培训签到
                </div>
                <div class="form-card">
                    <div class="form-row">
                        <div class="form-group">
                            <label>报名记录ID</label>
                            <input type="text" id="signinRegId" placeholder="请输入报名ID">
                        </div>
                        <div class="form-group">
                            <label>签到方式</label>
                            <select id="signinType" class="form-control">
                                <option value="扫码签到">📱 扫码签到</option>
                                <option value="手动签到">✍️ 手动签到</option>
                            </select>
                        </div>
                        <button class="btn btn-success" onclick="doSignin()">✅ 确认签到</button>
                    </div>
                    <div id="signinResult" class="result-box" style="display: none;"></div>
                </div>
            </div>

            <!-- 讲师评分（自动使用当前登录用户） -->
            <div class="section">
                <div class="section-title">
                    <span>⭐</span> 讲师评分
                </div>
                <div class="form-card">
                    <div class="form-row">
                        <div class="form-group">
                            <label>选择课程</label>
                            <select id="rateCourseId" class="form-control"></select>
                        </div>
                        <div class="form-group">
                            <label>评分 (1-5)</label>
                            <input type="number" id="score" placeholder="1-5" min="1" max="5" step="0.5">
                        </div>
                        <div class="form-group">
                            <label>评价</label>
                            <input type="text" id="comment" placeholder="请输入评价">
                        </div>
                        <button class="btn btn-warning" onclick="rateTrainer()">⭐ 提交评分</button>
                    </div>
                    <div id="rateResult" class="result-box" style="display: none;"></div>
                </div>
            </div>
        </div>

        <!-- 我的培训 Tab（自动使用当前登录用户） -->
        <div id="myTrainingTab" class="tab-content" style="display: none;">
            <div class="section">
                <div class="section-title">
                    <span>📋</span> 我的报名记录
                </div>
                <div class="table-container">
                    <table class="data-table" id="myRegTable">
                        <thead>
                            <tr>
                                <th>课程名称</th>
                                <th>状态</th>
                                <th>获得学时</th>
                                <th>签到时间</th>
                                <th>课程时间</th>
                                <th>地点</th>
                            </tr>
                        </thead>
                        <tbody></tbody>
                    </table>
                </div>
            </div>
        </div>

        <!-- 讲师风采 Tab -->
        <div id="trainersTab" class="tab-content" style="display: none;">
            <div class="section">
                <div class="section-title">
                    <span>⭐</span> 讲师列表
                </div>
                <div class="table-container">
                    <table class="data-table" id="trainersTable">
                        <thead>
                            <tr>
                                <th>讲师姓名</th>
                                <th>职称</th>
                                <th>所属机构</th>
                                <th>星级</th>
                                <th>类型</th>
                            </tr>
                        </thead>
                        <tbody></tbody>
                    </table>
                </div>
            </div>
        </div>

        <!-- 数据统计 Tab -->
        <div id="statsTab" class="tab-content" style="display: none;">
            <div class="section">
                <div class="section-title">
                    <span>📊</span> 课程报名统计
                </div>
                <div class="table-container">
                    <table class="data-table" id="courseStatsTable">
                        <thead>
                            <tr>
                                <th>课程名称</th>
                                <th>最大人数</th>
                                <th>已报名</th>
                                <th>剩余名额</th>
                                <th>状态</th>
                            </tr>
                        </thead>
                        <tbody></tbody>
                    </table>
                </div>
            </div>
        </div>

        <div class="footer">
            <p>© 2026 企业内部培训管理系统 | 数据实时同步于Oracle数据库</p>
        </div>
    </div>

    <script>
        // ============= 用户登录相关 =============
        
        // 获取当前登录用户
        function getCurrentUser() {
            const userStr = sessionStorage.getItem('user');
            if (!userStr) {
                window.location.href = '/';
                return null;
            }
            return JSON.parse(userStr);
        }
        
        // 显示用户信息
        function displayUserInfo() {
            const user = getCurrentUser();
            if (user) {
                document.getElementById('userName').textContent = user.empName;
                document.getElementById('userDept').textContent = user.deptName || '员工';
            }
        }
        
        // 退出登录
        function logout() {
            sessionStorage.removeItem('user');
            window.location.href = '/';
        }
        
        // ============= Tab切换 =============
        function showTab(tabName) {
            document.querySelectorAll('.tab-content').forEach(tab => {
                tab.style.display = 'none';
            });
            document.getElementById(tabName + 'Tab').style.display = 'block';
            
            document.querySelectorAll('.nav-btn').forEach(btn => {
                btn.classList.remove('active');
            });
            event.target.classList.add('active');
            
            // 刷新对应Tab的数据
            if (tabName === 'myTraining') {
                loadMyRegistrations();
            }
        }
        
        // 显示提示信息
        function showResult(elementId, message, type) {
            const element = document.getElementById(elementId);
            element.textContent = message;
            element.className = 'result-box ' + type;
            element.style.display = 'block';
            setTimeout(() => {
                element.style.display = 'none';
            }, 5000);
        }
        
        // ============= 课程相关 =============
        
        // 加载课程列表
        async function loadCourses() {
            try {
                const response = await fetch('/api/courses');
                const data = await response.json();
                const tbody = document.querySelector('#coursesTable tbody');
                const checkSelect = document.querySelector('#checkCourseId');
                const rateSelect = document.querySelector('#rateCourseId');
                
                if (data.success && data.data.length > 0) {
                    tbody.innerHTML = data.data.map(course => `
                        <tr>
                            <td><strong>${course.COURSE_NAME}</strong></td>
                            <td>${course.COURSE_TYPE || '-'}</td>
                            <td>${course.TRAINER_NAME || '-'} ${course.STAR_LEVEL ? '⭐'.repeat(course.STAR_LEVEL) : ''}</td>
                            <td>${course.DURATION}小时</td>
                            <td>${new Date(course.START_TIME).toLocaleString()}</td>
                            <td>${course.LOCATION || '-'}</td>
                            <td><button class="btn btn-primary btn-sm" onclick="registerCourse(${course.COURSE_ID})">报名</button></td>
                        `,
                    ).join('');
                    
                    const options = data.data.map(course => 
                        `<option value="${course.COURSE_ID}">${course.COURSE_NAME}</option>`
                    ).join('');
                    checkSelect.innerHTML = options;
                    rateSelect.innerHTML = options;
                } else {
                    tbody.innerHTML = '<tr><td colspan="7" style="text-align:center">暂无课程数据</td></tr>';
                }
            } catch (error) {
                console.error('加载课程失败:', error);
            }
        }
        
        // 报名课程（自动使用当前登录用户）
        async function registerCourse(courseId) {
            const user = getCurrentUser();
            if (!user) return;
            
            if (!confirm('确认报名该课程吗？')) return;
            
            try {
                const response = await fetch('/api/register', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ empId: user.empId, courseId: courseId })
                });
                const result = await response.json();
                if (result.success) {
                    alert('✅ ' + result.message);
                } else {
                    alert('❌ ' + result.error);
                }
            } catch (error) {
                alert('报名失败：' + error.message);
            }
        }
        
        // 冲突检测（自动使用当前登录用户）
        async function checkConflict() {
            const user = getCurrentUser();
            if (!user) return;
            const courseId = document.getElementById('checkCourseId').value;
            
            try {
                const response = await fetch('/api/check-conflict', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ empId: user.empId, courseId: parseInt(courseId) })
                });
                const result = await response.json();
                showResult('conflictResult', result.message, result.hasConflict ? 'error' : 'success');
            } catch (error) {
                showResult('conflictResult', '检测失败：' + error.message, 'error');
            }
        }
        
        // 签到
        async function doSignin() {
            const regId = document.getElementById('signinRegId').value;
            const signinType = document.getElementById('signinType').value;
            
            if (!regId) {
                showResult('signinResult', '请填写报名记录ID', 'error');
                return;
            }
            
            try {
                const response = await fetch('/api/signin', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ regId: parseInt(regId), signinType: signinType })
                });
                const result = await response.json();
                if (result.success) {
                    showResult('signinResult', result.message, 'success');
                    document.getElementById('signinRegId').value = '';
                } else {
                    showResult('signinResult', result.error, 'error');
                }
            } catch (error) {
                showResult('signinResult', '签到失败：' + error.message, 'error');
            }
        }
        
        // 讲师评分（自动使用当前登录用户）
        async function rateTrainer() {
            const user = getCurrentUser();
            if (!user) return;
            
            const courseId = document.getElementById('rateCourseId').value;
            const score = document.getElementById('score').value;
            const comment = document.getElementById('comment').value;
            
            if (!score || score < 1 || score > 5) {
                showResult('rateResult', '请填写1-5之间的评分', 'error');
                return;
            }
            
            try {
                // 获取课程对应的讲师ID
                const coursesResp = await fetch('/api/courses');
                const courses = await coursesResp.json();
                const course = courses.data.find(c => c.COURSE_ID == courseId);
                
                if (!course) {
                    showResult('rateResult', '课程不存在', 'error');
                    return;
                }
                
                const response = await fetch('/api/rate-trainer', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        courseId: parseInt(courseId),
                        trainerId: course.TRAINER_ID,
                        empId: user.empId,
                        score: parseFloat(score),
                        comment: comment || ''
                    })
                });
                const result = await response.json();
                if (result.success) {
                    showResult('rateResult', result.message, 'success');
                    document.getElementById('score').value = '';
                    document.getElementById('comment').value = '';
                } else {
                    showResult('rateResult', result.error, 'error');
                }
            } catch (error) {
                showResult('rateResult', '评分失败：' + error.message, 'error');
            }
        }
        
        // ============= 统计数据 =============
        
        // 加载KPI数据
        async function loadKPI() {
            try {
                const response = await fetch('/api/kpi');
                const data = await response.json();
                if (data.success && data.data.length > 0) {
                    document.getElementById('kpiData').innerHTML = data.data.map(dept => `
                        <div class="stat-item">
                            <span class="label">${dept.DEPT_NAME}</span>
                            <span class="value">${dept.COMPLETION_RATE || 0}% (${dept.COMPLETED_EMP || 0}/${dept.TOTAL_EMP || 0})</span>
                        </div>
                        <div class="kpi-bar">
                            <div class="kpi-fill" style="width: ${dept.COMPLETION_RATE || 0}%"></div>
                        </div>
                    `).join('');
                } else {
                    document.getElementById('kpiData').innerHTML = '<div class="stat-item">暂无数据</div>';
                }
            } catch (error) {
                document.getElementById('kpiData').innerHTML = '<div class="stat-item">加载失败</div>';
            }
        }
        
        // 加载预算数据
        async function loadBudget() {
            try {
                const response = await fetch('/api/budget');
                const data = await response.json();
                if (data.success && data.data.length > 0) {
                    document.getElementById('budgetData').innerHTML = data.data.map(budget => {
                        let usageClass = '';
                        if (budget.USAGE_RATE > 80) usageClass = 'usage-high';
                        else if (budget.USAGE_RATE > 50) usageClass = 'usage-medium';
                        else usageClass = 'usage-low';
                        return `
                            <div class="stat-item">
                                <span class="label">${budget.DEPT_NAME}</span>
                                <span class="value">¥${budget.USED_BUDGET} / ¥${budget.ANNUAL_BUDGET}</span>
                            </div>
                            <div class="kpi-bar">
                                <div class="kpi-fill" style="width: ${budget.USAGE_RATE}%"></div>
                            </div>
                            <div class="stat-item">
                                <span class="label">剩余预算</span>
                                <span class="value ${usageClass}">¥${budget.REMAIN_BUDGET}</span>
                            </div>
                        `;
                    }).join('');
                } else {
                    document.getElementById('budgetData').innerHTML = '<div class="stat-item">暂无数据</div>';
                }
            } catch (error) {
                document.getElementById('budgetData').innerHTML = '<div class="stat-item">加载失败</div>';
            }
        }
        
        // 加载我的报名记录（自动使用当前登录用户）
        async function loadMyRegistrations() {
            const user = getCurrentUser();
            if (!user) return;
            
            try {
                const response = await fetch(`/api/my-registrations/${user.empId}`);
                const data = await response.json();
                const tbody = document.querySelector('#myRegTable tbody');
                if (data.success && data.data.length > 0) {
                    tbody.innerHTML = data.data.map(reg => `
                        <tr>
                            <td><strong>${reg.COURSE_NAME}</strong></td>
                            <td><span class="status-badge ${reg.STATUS === '已签到' ? 'status-signed' : 'status-booked'}">${reg.STATUS}</span></td>
                            <td>${reg.ACTUAL_HOURS || 0}小时</td>
                            <td>${reg.SIGNIN_TIME ? new Date(reg.SIGNIN_TIME).toLocaleString() : '-'}</td>
                            <td>${new Date(reg.START_TIME).toLocaleDateString()}</td>
                            <td>${reg.LOCATION || '-'}</td>
                        `,
                    ).join('');
                } else {
                    tbody.innerHTML = '<tr><td colspan="6" style="text-align:center">暂无报名记录</td></tr>';
                }
            } catch (error) {
                console.error('加载报名记录失败:', error);
            }
        }
        
        // 加载讲师列表
        async function loadTrainers() {
            try {
                const response = await fetch('/api/trainers');
                const data = await response.json();
                const tbody = document.querySelector('#trainersTable tbody');
                if (data.success && data.data.length > 0) {
                    tbody.innerHTML = data.data.map(trainer => `
                        <tr>
                            <td><strong>${trainer.TRAINER_NAME}</strong></td>
                            <td>${trainer.TITLE || '-'}</td>
                            <td>${trainer.COMPANY || '-'}</td>
                            <td><span class="stars">${'⭐'.repeat(trainer.STAR_LEVEL || 3)}</span> (${trainer.STAR_LEVEL || 3}星)</td>
                            <td><span class="status-badge ${trainer.IS_INTERNAL === '是' ? 'status-published' : 'status-booked'}">${trainer.IS_INTERNAL === '是' ? '内部讲师' : '外部讲师'}</span></td>
                        `,
                    ).join('');
                } else {
                    tbody.innerHTML = '<tr><td colspan="5" style="text-align:center">暂无讲师数据</td></tr>';
                }
            } catch (error) {
                console.error('加载讲师失败:', error);
            }
        }
        
        // 加载课程统计
        async function loadCourseStats() {
            try {
                const response = await fetch('/api/course-stats');
                const data = await response.json();
                const tbody = document.querySelector('#courseStatsTable tbody');
                if (data.success && data.data.length > 0) {
                    tbody.innerHTML = data.data.map(stat => {
                        let statusClass = '';
                        let statusText = '';
                        if (stat.REMAINING_SLOTS === 0) {
                            statusClass = 'status-closed';
                            statusText = '已满';
                        } else if (stat.REMAINING_SLOTS < 5) {
                            statusClass = 'status-warning';
                            statusText = '即将满员';
                        } else {
                            statusClass = 'status-published';
                            statusText = '可报名';
                        }
                    return `
                                <tr>
                                    <td><strong>${stat.COURSE_NAME}</strong></td>
                                    <td>${stat.MAX_STUDENTS}</td>
                                    <td>${stat.REGISTERED_COUNT}</td>
                                    <td>${stat.REMAINING_SLOTS}</td>
                                    <td><span class="status-badge ${statusClass}">${statusText}</span></td>
                                </tr>
                            `;
                        }).join('');
                } else {
                    tbody.innerHTML = '<tr><td colspan="5" style="text-align:center">暂无数据</td></tr>';
                }
            } catch (error) {
                console.error('加载课程统计失败:', error);
            }
        }
        
        // ============= 页面初始化 =============
        window.addEventListener('DOMContentLoaded', () => {
            displayUserInfo();
            loadCourses();
            loadKPI();
            loadBudget();
            loadTrainers();
            loadCourseStats();
        });
    </script>
</body>
</html>